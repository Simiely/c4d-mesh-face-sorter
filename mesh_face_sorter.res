// C4D Mesh Face Sorter - Resource File
// Plugin: 按面数/顶点数/存储大小排列场景中所有网格体

CONTAINER C4D_MESH_FACE_SORTER {
  NAME {
    ENUS "Mesh Face Sorter";
    ENGB "Mesh Face Sorter";
    CHS "网格排序器";
    ZHCN "网格排序器";
    JPN "メッシュソーター";
    KOR "메시 정렬기";
  };

  HELP {
    ENUS "Sort mesh objects by face count, vertex count, or estimated memory size. Supports isolation, empty mesh deletion, polygon reduction, and MD report export.";
    ENGB "Sort mesh objects by face count, vertex count, or estimated memory size. Supports isolation, empty mesh deletion, polygon reduction, and MD report export.";
    CHS "按面数、顶点数或估算内存大小排列网格体。支持孤立显示、删除空网格、减面和导出MD报表。";
    ZHCN "按面数、顶点数或估算内存大小排列网格体。支持孤立显示、删除空网格、减面和导出MD报表。";
  };

  REL_NOTES {
    ENUS "Initial release";
    CHS "初始版本";
    ZHCN "初始版本";
  };
};
