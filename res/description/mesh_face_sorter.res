// C4D Mesh Face Sorter - Description Resource

CONTAINER C4D_MESH_FACE_SORTER {
  NAME {
    ENUS "Mesh Face Sorter";
    CHS "网格排序器";
    ZHCN "网格排序器";
  };

  HELP {
    ENUS "Sort mesh objects by face/vertex count or estimated memory size. Supports isolation, deletion of empty meshes, polygon reduction, and MD report export.";
    CHS "按面数/顶点数/存储大小排列网格体。支持孤立显示、删除空网格、减面、导出MD报表。";
    ZHCN "按面数/顶点数/存储大小排列网格体。支持孤立显示、删除空网格、减面、导出MD报表。";
  };
};
